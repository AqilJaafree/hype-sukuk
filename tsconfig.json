{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["mocha", "chai", "node"]
  },
  "include": ["tests/**/*.ts", "scripts/**/*.ts", "app/**/*.ts"]
}
