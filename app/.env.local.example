# ── Frontend-only env vars (safe to expose to browser) ───────────────────────
NEXT_PUBLIC_ZKME_APP_ID=your_mchno_from_dashboard
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com?api-key=<your_key>

# NOTE: The TEE auth token is generated server-side and NEVER exposed to the
# frontend. The browser connects to the ER indirectly via API routes.
