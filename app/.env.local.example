# ── Frontend-only env vars (safe to expose to browser) ───────────────────────
NEXT_PUBLIC_ZKME_APP_ID=your_mchno_from_dashboard
# Points to the local RPC proxy — Helius API key stays server-side in SOLANA_RPC_URL
NEXT_PUBLIC_SOLANA_RPC_URL=/api/rpc
NEXT_PUBLIC_SUKUK_MINT=<sukuk_mint_pubkey>

# ── Server-side only (API routes) ────────────────────────────────────────────
# Real Helius URL with API key — never exposed to browser
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=<your_key>
ZKME_API_KEY=<from_zkme_dashboard>
ZKME_APP_ID=<same_as_NEXT_PUBLIC_ZKME_APP_ID>
SUKUK_MINT=<sukuk_mint_pubkey>
AUTHORITY_SECRET_KEY=<deployer_keypair_json_array_or_base58>
