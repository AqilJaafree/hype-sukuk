  "types": [
    {
      "name": "AccrualState",
      "docs": [
        "Per-holder profit accrual state.",
        "Created inside the rollup session; written back to base Solana on settlement.",
        "",
        "seeds: [\"accrual_state\", mint, holder]",
        "space: 8 + 32 + 32 + 8 + 8 + 8 + 1 = 97"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "holder",
            "docs": [
              "The holder's wallet pubkey."
            ],
            "type": "pubkey"
          },
          {
            "name": "mint",
            "docs": [
              "The sukuk token mint."
            ],
            "type": "pubkey"
          },
          {
            "name": "accrued_profit_usdc",
            "docs": [
              "Accumulated profit in USDC (6 decimals)."
            ],
            "type": "u64"
          },
          {
            "name": "last_tick",
            "docs": [
              "Unix timestamp of the last accrual tick."
            ],
            "type": "i64"
          },
          {
            "name": "token_balance_snapshot",
            "docs": [
              "Sukuk token balance snapshot at the last tick.",
              "Updated each tick so balance changes are reflected progressively."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "ClaimProfitArgs",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "amount_usdc",
            "docs": [
              "Amount of USDC (6 decimals) the holder is claiming — must match the leaf."
            ],
            "type": "u64"
          },
          {
            "name": "leaf_index",
            "docs": [
              "Index of the holder's leaf in the Merkle tree."
            ],
            "type": "u32"
          },
          {
            "name": "proof",
            "docs": [
              "Sibling hashes forming the Merkle proof path."
            ],
            "type": {
              "vec": {
                "array": [
                  "u8",
                  32
                ]
              }
            }
          }
        ]
      }
    },
    {
      "name": "ClaimReceipt",
      "docs": [
        "Created when a holder claims their profit from a distribution period.",
        "Existence of this PDA prevents double-claiming.",
        "",
        "seeds: [\"claim_receipt\", distribution_root, holder]",
        "space: 8 + 32 + 8 + 8 + 1 = 57"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "holder",
            "docs": [
              "The holder that submitted the claim."
            ],
            "type": "pubkey"
          },
          {
            "name": "amount_usdc",
            "docs": [
              "Amount of USDC (6 decimals) transferred to the holder."
            ],
            "type": "u64"
          },
          {
            "name": "claimed_at",
            "docs": [
              "Unix timestamp of the claim."
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "CommitDistributionArgs",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "period_start",
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "DistributionCommitted",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "mint",
            "type": "pubkey"
          },
          {
            "name": "merkle_root",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "total_usdc",
            "type": "u64"
          },
          {
            "name": "period_end",
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "DistributionRoot",
      "docs": [
        "Merkle root of all accrual states for a profit distribution period.",
        "Written by commit_distribution inside the rollup, then committed to base",
        "Solana during undelegate_and_settle.",
        "",
        "seeds: [\"distribution_root\", mint, period_start_as_le_bytes]",
        "space: 8 + 32 + 32 + 8 + 8 + 8 + 8 + 1 + 1 = 106"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "mint",
            "type": "pubkey"
          },
          {
            "name": "merkle_root",
            "docs": [
              "SHA-256 Merkle root over all (holder, accrued_profit_usdc) leaves."
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "total_profit_usdc",
            "docs": [
              "Total USDC across all holders (6 decimals)."
            ],
            "type": "u64"
          },
          {
            "name": "period_start",
            "type": "i64"
          },
          {
            "name": "period_end",
            "type": "i64"
          },
          {
            "name": "holder_count",
            "type": "u64"
          },
          {
            "name": "committed",
            "docs": [
              "Set true after commit_distribution. Guards against double-commit."
            ],
            "type": "bool"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "OrderSide",
