# ── zkMe — NEVER expose to frontend ──────────────────────────────────────────
ZKME_API_KEY=your_api_key_from_dashboard
ZKME_APP_ID=your_mchno_from_dashboard
ZKME_CREDENTIAL_MINT=zkMe_SBT_mint_pubkey_on_solana

# ── Solana base layer (Helius devnet) ─────────────────────────────────────────
SOLANA_RPC_URL=https://devnet.helius-rpc.com?api-key=<your_key>
SUKUK_HOOK_PROGRAM_ID=<set after anchor build>
SUKUK_ROLLUP_PROGRAM_ID=<set after anchor build>
SUKUK_MINT=<set after initialize_sukuk_mint>

# ── MagicBlock Private ER (TEE devnet) ────────────────────────────────────────
# authToken is generated at runtime via createTeeSession() — do NOT hardcode here.
# The TEE endpoint requires a signed challenge exchange; see app/lib/magicblock-tee.ts
MAGICBLOCK_TEE_ENDPOINT=https://tee.magicblock.app
MAGICBLOCK_TEE_WS_ENDPOINT=wss://tee.magicblock.app

# ── Oracle keypair (server-side only, never commit) ───────────────────────────
KYC_ORACLE_SECRET_KEY=<base58 secret key for kyc_oracle keypair>
AUTHORITY_SECRET_KEY=<JSON array of authority keypair bytes>

# ── Helius webhook ────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key
HELIUS_WEBHOOK_SECRET=your_helius_webhook_signing_secret
